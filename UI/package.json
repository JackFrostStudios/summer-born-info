{
  "name": "summer-born-info",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:localize": "ng build --configuration production,localized",
    "check:asset-sizes": "node ./scripts/check-asset-sizes.mjs",
    "check:localized-ssr-assets": "node ./scripts/check-localized-ssr-assets.mjs",
    "extract:i18n": "ng run summer-born-info:extract-i18n",
    "validate:i18n": "npm run extract:i18n && git diff --exit-code -- src/locale/messages.xlf && npm run build:localize && npm run check:localized-ssr-assets",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:run": "ng test --watch=false",
    "test:a11y": "node ./scripts/run-a11y-tests.mjs",
    "test:coverage": "ng test --watch=false --coverage",
    "test:ci": "npm run test:coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve:ssr:summer-born-info": "node dist/summer-born-info/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.1.0",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || ^26.0.0"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/localize": "^22.0.2",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.3",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.8"
  }
}
